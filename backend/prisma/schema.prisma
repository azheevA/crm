// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id              Int @default(autoincrement()) @id
  email           String @unique
  name            String
  hash            String
  resetCode       String?
  resetCodeExp    DateTime?
  chats           ChatMember[]
  messages        Message[]
  avatar          Photo? @relation("UserAvatar")
  account         Account?
  activities      Activity[]
  managedDeals    Deal[]    @relation("DealOwner")
  tasks           Task[]
}

model Chat {
  id        Int       @id @default(autoincrement())

  title     String?
  isGroup   Boolean   @default(false)

  members   ChatMember[]

  messages  Message[] @relation("ChatMessages")

  lastMessageId Int?
  lastMessage   Message? @relation("ChatLastMessage", fields: [lastMessageId], references: [id])

  createdAt DateTime @default(now())
}

model ChatMember {
  id      Int @id @default(autoincrement())

  chatId  Int
  userId  Int

  chat    Chat @relation(fields: [chatId], references: [id])
  user    User @relation(fields: [userId], references: [id])

  lastReadMessageId Int?

  role              String @default("member")

  joinedAt          DateTime @default(now())

  @@unique([chatId, userId])
}

model Message {
  id        Int      @id @default(autoincrement())
  text      String

  chatId    Int
  authorId  Int

  chat      Chat @relation("ChatMessages", fields: [chatId], references: [id])
  lastInChats Chat[]   @relation("ChatLastMessage")
  author    User? @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())

  files     Photo[] @relation("MessageFiles")

  @@index([chatId, createdAt])
}

model Company {
  id            Int       @id @default(autoincrement())
  name          String
  website       String?
  contacts      Contact[]
  deals         Deal[]
  createdAt     DateTime  @default(now())
  activities    Activity[]
}

model Contact {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  phone     String?
  companyId Int
  company   Company  @relation(fields: [companyId], references: [id])
  deals     Deal[]
}

model Deal {
  id          Int      @id @default(autoincrement())
  title       String
  amount      Float    @default(0)
  companyId   Int
  company     Company  @relation(fields: [companyId], references: [id])
  contactId   Int?  
  contact     Contact?   @relation(fields: [contactId], references: [id])
  ownerId     Int
  owner       User     @relation("DealOwner", fields: [ownerId], references: [id])
  files       Photo[]      @relation("DealFiles")
  tasks       Task[]
  activities  Activity[]
  status      DealStatus @default(NEW)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  dueDate     DateTime
  isCompleted Boolean  @default(false)
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  dealId      Int?
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
}



model Photo {
  id           Int      @id @default(autoincrement())
  url          String
  filename     String
  originalName String
  createdAt    DateTime @default(now())

  userId       Int?     @unique
  user         User?    @relation("UserAvatar", fields: [userId], references: [id], onDelete: Cascade)

  messageId    Int?
  message      Message? @relation("MessageFiles", fields: [messageId], references: [id], onDelete: Cascade)

  dealId       Int?
  deal         Deal?    @relation("DealFiles", fields: [dealId], references: [id], onDelete: Cascade)
}


model Account{
  id          Int @id @default(autoincrement())
  ownerId     Int @unique
  owner       User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model Activity {
  id        Int          @id @default(autoincrement())
  type      ActivityType @default(COMMENT)
  content   String    
  userId    Int
  user      User         @relation(fields: [userId], references: [id])
  companyId Int?
  company   Company?     @relation(fields: [companyId], references: [id])
  
  dealId    Int?
  deal      Deal?        @relation(fields: [dealId], references: [id])

  createdAt DateTime     @default(now())
}

enum ActivityType {
  COMMENT 
  STAGE_CHANGE
  VALUE_CHANGE 
  TASK_CREATED
  TASK_UPDATED 
  TASK_DELETED
  FILE_ADDED  
  CHAT_MESSAGE 
}

enum DealStatus {
  NEW
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}