// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
  
}

model User{
  id Int @default(autoincrement()) @id
  email String @unique
  name String
  hash String
  resetCode String?
  resetCodeExp DateTime?
  items Message[]
  avatar Photo? @relation("UserAvatar")
  account Account?
}
model Message {
  id        Int      @default(autoincrement()) @id
  text      String
  author    User?    @relation(fields: [authorId], references: [id])
  authorId  Int?
  createdAt DateTime @default(now())
  files     Photo[]   @relation("MessageFiles")
}
model Photo {
  id           Int      @id @default(autoincrement())
  url          String
  filename     String
  originalName String
  userId       Int?     @unique
  user         User?    @relation("UserAvatar", fields: [userId], references: [id], onDelete: Cascade)
  messageId    Int?
  message      Message? @relation("MessageFiles", fields: [messageId], references: [id], onDelete: Cascade)
}
model Account{
  id Int @id @default(autoincrement())
  ownerId Int @unique
  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}
